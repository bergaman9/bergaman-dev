# MongoDB Connection - Atlas Cloud Database
# Replace with your actual MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_IMAGE_ALLOWED_HOSTS=bergaman.dev,www.bergaman.dev,i.scdn.co,open.spotify.com,www.google.com,github.com,avatars.githubusercontent.com,raw.githubusercontent.com,images.unsplash.com

MONGODB_DB=your-database-name
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# App Version (will be set by GitHub Actions in production)
NEXT_PUBLIC_APP_VERSION=v2.7.0

# Email Configuration for Contact Form
EMAIL_USER=your-email@gmail.com
EMAIL_PASS="your-gmail-app-password"

# Vercel Configuration (Optional - only needed for deployment)
VERCEL_TOKEN=your-vercel-token-here
VERCEL_ORG_ID=your-vercel-org-id-here
VERCEL_PROJECT_ID=your-vercel-project-id-here

# JWT Secret (güvenlik için güçlü bir değer kullanın)
JWT_SECRET=your-strong-jwt-secret-key-at-least-32-chars

# Admin kullanıcı bilgileri
# IMPORTANT: Change these values and keep them secret!
ADMIN_USERNAME=admin
# Preferred: bcrypt hash generated from a strong password.
ADMIN_PASSWORD_HASH=$2b$12$replace-with-your-bcrypt-hash
# Development fallback only; production should use ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=your-very-strong-password-here

# Rate Limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=900000

# Güvenlik ayarları
SECURE_COOKIES=true
SESSION_DURATION_HOURS=24

# API Rate Limiting
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW_MS=60000

# Webhook security
WEBHOOK_SHARED_SECRET=replace-with-shared-webhook-secret
EMAIL_WEBHOOK_SECRET=replace-with-email-webhook-secret
GMAIL_WEBHOOK_SECRET=replace-with-gmail-webhook-secret

# CORS ayarları
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Encryption key (32 karakter)
ENCRYPTION_KEY=32-character-encryption-key-here
